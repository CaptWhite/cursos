---
import { docList, docMapBySlug } from '../docMapping';
import type { MenuTab } from '../docMapping';

interface Props {
  title: string;
  currentSlug?: string;
}

const { title, currentSlug } = Astro.props;

const tabs: MenuTab[] = ['Cursos', 'IA', 'LOCAL', 'VPS', 'Tab5', 'Tab6'];
const activeTab = (docMapBySlug.get(currentSlug ?? '')?.menutab ?? tabs[0]) as MenuTab;

const tabFirstDoc: Record<string, string> = {};
for (const tab of tabs) {
  const first = docList.find(d => d.menutab === tab);
  if (first) tabFirstDoc[tab] = first.slug;
}
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Cursos Docs</title>
    
    <!-- Google Fonts: Crimson Pro (serif display) & DM Sans (body) & JetBrains Mono (code) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;500;600;700&family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    
    <!-- KaTeX CSS for LaTeX equations -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css">

    <!-- Mermaid CDN and Client-side Parser script -->
    <script type="module">
      import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';
      mermaid.initialize({
        theme: 'dark',
        startOnLoad: false,
        securityLevel: 'loose',
        fontFamily: 'DM Sans, system-ui, sans-serif',
        themeVariables: {
          primaryColor: '#d97706',
          primaryTextColor: '#fef3c7',
          primaryBorderColor: '#b45309',
          lineColor: '#92400e',
          secondaryColor: '#78350f',
          tertiaryColor: '#451a03'
        },
        flowchart: {
          useMaxWidth: true,
          htmlLabels: true
        }
      });

      const renderMermaid = async () => {
        const blocks = document.querySelectorAll('pre[data-language="mermaid"], pre.language-mermaid');
        if (blocks.length > 0) {
          blocks.forEach((preEl, index) => {
            const rawCode = preEl.textContent || '';
            const div = document.createElement('div');
            div.className = 'mermaid';
            div.id = `mermaid-${index}`;
            div.textContent = rawCode;
            
            if (preEl.parentNode) {
              preEl.parentNode.replaceChild(div, preEl);
            }
          });
          await mermaid.run();
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', renderMermaid);
      } else {
        renderMermaid();
      }
    </script>
  </head>
  <body>
    <!-- Subtle background texture -->
    <div class="bg-texture"></div>
    <div class="bg-gradient"></div>
    
    <div class="app-container">
      <!-- Top header / banner -->
      <header class="app-header">
        <div class="header-logo">
          <div class="brand-row">
            <span class="brand-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </span>
            <span class="brand-text">Cursos Docs</span>
          </div>
          <span class="brand-sub">Plataforma de Aprendizaje</span>
        </div>
        <div class="header-desc">Documentación Técnica y Académica</div>
      </header>

      <div class="workspace">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
          <nav class="menu-tabs" data-tab-first={JSON.stringify(tabFirstDoc)} data-current-slug={currentSlug ?? ''} data-active-tab={activeTab}>
            {tabs.map(tab => (
              <button class={`tab-btn${tab === activeTab ? ' active' : ''}`} data-tab={tab}>{tab}</button>
            ))}
          </nav>
          <div class="sidebar-header">
            <h3>Contenido</h3>
          </div>
          <nav class="sidebar-nav">
            <ul>
              {docList.map((item) => (
                <li data-menutab={item.menutab} hidden={item.menutab !== activeTab ? '' : undefined}>
                  <a 
                    href={`/${item.slug}`} 
                    class={`nav-link ${currentSlug === item.slug ? 'active' : ''} ${item.chapter.includes('.') ? 'sub-chapter' : ''}`}
                  >
                    <span class="chapter-number">{item.chapter}</span>
                    <span class="chapter-title">{item.description}</span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">
          <article class="content-card">
            <slot />
          </article>
        </main>
      </div>
    </div>

    <!-- Menu Tabs navigation script -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const nav = document.querySelector<HTMLElement>('.menu-tabs');
        if (!nav) return;

        const tabFirstDoc = JSON.parse(nav.dataset.tabFirst || '{}') as Record<string, string>;
        const currentSlug = nav.dataset.currentSlug || '';
        const activeTab = nav.dataset.activeTab || '';

        if (currentSlug && activeTab) {
          sessionStorage.setItem('tab-last-' + activeTab, currentSlug);
        }

        const tabs = nav.querySelectorAll<HTMLButtonElement>('.tab-btn');
        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            const target = tab.dataset.tab;
            if (!target || target === activeTab) return;
            const lastSlug = sessionStorage.getItem('tab-last-' + target);
            const slug = lastSlug || tabFirstDoc[target as string];
            if (slug) window.location.href = '/' + slug;
          });
        });
      });
    </script>
  </body>
</html>

<style is:global>
  /* Design System - Scholarly Dark Theme */
  :root {
    /* Core palette - warm amber/gold academic tones */
    --bg-deep: #0c0a09;
    --bg-surface: #1c1917;
    --bg-elevated: #292524;
    --bg-card: rgba(28, 25, 23, 0.85);
    
    /* Borders */
    --border-subtle: rgba(245, 158, 11, 0.08);
    --border-default: rgba(245, 158, 11, 0.12);
    --border-strong: rgba(245, 158, 11, 0.2);
    
    /* Text */
    --text-primary: #fafaf9;
    --text-secondary: #a8a29e;
    --text-muted: #78716c;
    
    /* Accent - Amber/Gold */
    --accent-primary: #f59e0b;
    --accent-secondary: #d97706;
    --accent-muted: rgba(245, 158, 11, 0.15);
    --accent-glow: rgba(245, 158, 11, 0.1);
    
    /* Semantic */
    --success: #22c55e;
    --info: #3b82f6;
    
    color-scheme: dark;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
    color: var(--text-primary);
    background-color: var(--bg-deep);
    min-height: 100vh;
    overflow-x: hidden;
    line-height: 1.6;
  }

  /* Background layers */
  .bg-texture {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    pointer-events: none;
  }

  .bg-gradient {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background: 
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(245, 158, 11, 0.08), transparent),
      radial-gradient(ellipse 60% 40% at 80% 50%, rgba(217, 119, 6, 0.04), transparent),
      radial-gradient(ellipse 60% 40% at 20% 80%, rgba(180, 83, 9, 0.03), transparent);
    pointer-events: none;
  }

  .app-container {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    padding: 1.5rem;
    max-width: 1600px;
    margin: 0 auto;
    z-index: 1;
    position: relative;
  }

  /* App Header */
  .app-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.75rem;
    background: var(--bg-card);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    margin-bottom: 1.5rem;
    box-shadow: 
      0 1px 2px rgba(0, 0, 0, 0.3),
      0 4px 16px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.02);
  }

  .header-logo {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .brand-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .brand-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    border-radius: 8px;
    color: var(--bg-deep);
  }

  .brand-text {
    font-family: 'Crimson Pro', Georgia, serif;
    font-weight: 700;
    font-size: 1.35rem;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .brand-sub {
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-left: calc(36px + 0.75rem);
  }

  .header-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* Menu Tabs Bar */
  .menu-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    padding: 0.75rem;
    margin-bottom: 0;
    background: transparent;
    border-bottom: 1px solid var(--border-subtle);
  }

  .tab-btn {
    flex: 1;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.75rem;
    padding: 0.5rem 0.625rem;
    border: 1px solid transparent;
    border-radius: 6px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
    letter-spacing: 0.02em;
  }

  .tab-btn:hover {
    color: var(--text-primary);
    background: var(--bg-elevated);
    border-color: var(--border-subtle);
  }

  .tab-btn.active {
    color: var(--bg-deep);
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    border-color: var(--accent-primary);
    box-shadow: 0 2px 8px rgba(245, 158, 11, 0.3);
  }

  /* Workspace Layout */
  .workspace {
    display: flex;
    gap: 1.5rem;
    flex: 1;
  }

  /* Sidebar Navigation */
  .sidebar {
    width: 300px;
    background: var(--bg-card);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    height: calc(100vh - 11rem);
    position: sticky;
    top: 1.5rem;
    box-shadow: 
      0 1px 2px rgba(0, 0, 0, 0.2),
      0 4px 16px rgba(0, 0, 0, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.02);
  }

  .sidebar-header {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  .sidebar-header h3 {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-secondary);
    text-transform: uppercase;
  }

  .sidebar-nav {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem;
  }

  .sidebar-nav::-webkit-scrollbar {
    width: 4px;
  }

  .sidebar-nav::-webkit-scrollbar-track {
    background: transparent;
  }

  .sidebar-nav::-webkit-scrollbar-thumb {
    background: var(--border-default);
    border-radius: 2px;
  }

  .sidebar-nav ul {
    list-style: none;
  }

  .sidebar-nav li {
    margin-bottom: 0;
  }

  .sidebar-nav li[hidden] {
    display: none;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.625rem;
    border-radius: 6px;
    text-decoration: none;
    color: var(--text-secondary);
    transition: all 0.15s ease;
    font-size: 0.8125rem;
    border: 1px solid transparent;
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: var(--bg-elevated);
    border-color: var(--border-subtle);
  }

  .nav-link.active {
    color: var(--text-primary);
    background: var(--accent-muted);
    border-color: var(--border-strong);
  }

  .chapter-number {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
    color: var(--accent-primary);
    min-width: 1.75rem;
    font-size: 0.6875rem;
    background: rgba(245, 158, 11, 0.1);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    text-align: center;
  }

  .nav-link.active .chapter-number {
    color: var(--bg-deep);
    background: var(--accent-primary);
  }

  .chapter-title {
    line-height: 1.4;
    flex: 1;
  }

  .nav-link.sub-chapter {
    padding-left: 1.5rem;
    font-size: 0.75rem;
    opacity: 0.9;
    border-left: 2px solid var(--border-subtle);
    border-radius: 0 6px 6px 0;
  }

  .nav-link.sub-chapter.active {
    border-left-color: var(--accent-primary);
  }

  /* Main Content Area */
  .main-content {
    flex: 1;
    min-width: 0;
  }

  .content-card {
    background: var(--bg-card);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 2.5rem;
    min-height: 100%;
    box-shadow: 
      0 1px 2px rgba(0, 0, 0, 0.2),
      0 8px 32px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.02);
  }

  /* Markdown Content Typography */
  article {
    line-height: 1.75;
    font-size: 1rem;
  }

  article h1, article h2, article h3, article h4 {
    font-family: 'Crimson Pro', Georgia, serif;
    color: var(--text-primary);
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  article h1 {
    font-size: 2.25rem;
    border-bottom: 1px solid var(--border-subtle);
    padding-bottom: 1rem;
    margin-top: 0;
    color: var(--accent-primary);
  }

  article h2 {
    font-size: 1.625rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--border-subtle);
    color: var(--text-primary);
  }

  article h3 {
    font-size: 1.25rem;
    color: var(--accent-secondary);
  }

  article p {
    margin-bottom: 1.25rem;
    color: var(--text-primary);
  }

  article strong {
    color: var(--accent-primary);
    font-weight: 600;
  }

  article a {
    color: var(--accent-primary);
    text-decoration: none;
    border-bottom: 1px dashed var(--accent-secondary);
    transition: all 0.15s ease;
  }

  article a:hover {
    color: var(--accent-secondary);
    border-bottom-style: solid;
  }

  /* Lists */
  article ul, article ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  article li {
    margin-bottom: 0.5rem;
  }

  article li::marker {
    color: var(--accent-secondary);
  }

  /* Blockquotes & Alerts */
  article blockquote {
    border-left: 3px solid var(--accent-primary);
    background: var(--accent-muted);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 0 8px 8px 0;
    font-style: italic;
  }

  article blockquote p {
    margin-bottom: 0;
    color: var(--text-secondary);
  }

  /* Code Block styling */
  article pre {
    background: var(--bg-surface) !important;
    border: 1px solid var(--border-default);
    border-radius: 8px;
    padding: 1.25rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    line-height: 1.6;
  }

  article code {
    font-family: 'JetBrains Mono', monospace;
    background: var(--bg-elevated);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.875em;
    color: var(--accent-primary);
  }

  article pre code {
    background: transparent;
    padding: 0;
    color: var(--text-primary);
    font-size: inherit;
  }

  /* Mermaid diagram sizing */
  .mermaid {
    width: 100%;
    max-width: 700px;
    margin: 1.5rem auto;
    text-align: center;
  }

  .mermaid svg {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
  }

  /* Markdown Tables styling */
  article table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9375rem;
  }

  article th, article td {
    padding: 0.75rem 1rem;
    border: 1px solid var(--border-default);
    text-align: left;
  }

  article th {
    background: var(--bg-elevated);
    font-family: 'Crimson Pro', Georgia, serif;
    font-weight: 600;
    color: var(--accent-primary);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  article tr:nth-child(even) td {
    background: rgba(255, 255, 255, 0.01);
  }

  article tr:hover td {
    background: var(--accent-muted);
  }

  /* KaTeX Math Blocks layout adjustments */
  .katex-display {
    padding: 1rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    overflow-y: hidden;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
  }

  /* Bulletproof hiding of MathML source nodes */
  .katex-mathml {
    display: none !important;
  }

  /* Scrollbars styling */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  ::-webkit-scrollbar-track {
    background: transparent;
  }

  ::-webkit-scrollbar-thumb {
    background: var(--border-default);
    border-radius: 3px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--border-strong);
  }

  /* Selection */
  ::selection {
    background: var(--accent-muted);
    color: var(--text-primary);
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .workspace {
      flex-direction: column;
    }
    
    .sidebar {
      width: 100%;
      height: auto;
      max-height: 300px;
      position: relative;
      top: 0;
    }

    .content-card {
      padding: 1.5rem;
    }
  }

  @media (max-width: 640px) {
    .app-container {
      padding: 1rem;
    }

    .app-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .header-desc {
      display: none;
    }

    .brand-sub {
      padding-left: 0;
    }

    .content-card {
      padding: 1.25rem;
    }

    article h1 {
      font-size: 1.75rem;
    }

    article h2 {
      font-size: 1.375rem;
    }
  }
</style>
